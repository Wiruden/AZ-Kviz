<UserControl x:Class="az_kviz.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <Border CornerRadius="15" Background="White" Margin="40" Padding="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Version}" FontSize="14" Foreground="#7F8C8D" Margin="0,0,0,20"/>

            <TextBlock Text="{Binding Description}" FontSize="16" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="500" LineHeight="22"/>

            <TextBlock Text="{Binding Technologies}" FontSize="14" FontStyle="Italic" Margin="0,20,0,0" Foreground="#34495E"/>
            <TextBlock Text="{Binding Author}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,30"/>

            <Button Content="BACK TO MENU" 
                    Command="{Binding DataContext.ShowMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="200" Height="45" 
                    Background="White" Foreground="Black" 
                    FontSize="16" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Border>
</UserControl>
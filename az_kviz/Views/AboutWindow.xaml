<Window x:Class="az_kviz.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:az_kviz"
        mc:Ignorable="d"
        Title="AboutWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Border BorderBrush="Black" BorderThickness="2" Padding="20">
            <StackPanel>
                <TextBlock Text="AZ KVÍZ PROJECT" FontSize="26" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Separator Background="Black" Margin="0,0,0,15"/>

                <TextBlock Text="Author: David Mihók (4.C)" FontSize="16" Margin="0,0,0,5"/>
                <TextBlock Text="Subject: Programming and App Development" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Project Goal:" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="A desktop educational quiz game where players compete to connect three sides of a hexagonal board." 
                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="Technologies Used:" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="WPF, C#, XAML, JSON" Margin="0,0,0,20"/>

                <Separator Background="Black" Margin="0,0,0,15"/>

                <DockPanel LastChildFill="False">
                    <Button Content="BACK" DockPanel.Dock="Right" Width="80" Height="30"
                            Background="White" BorderBrush="Black" BorderThickness="2" 
                            Click="CloseButton_Click"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

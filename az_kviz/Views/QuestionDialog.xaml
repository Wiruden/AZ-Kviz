<Window x:Class="az_kviz.Views.QuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Question" Height="300" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding QuestionText}" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

            <ProgressBar Value="{Binding TimerValue}" Maximum="15" Height="10" Margin="0,0,0,10" Foreground="Orange"/>

            <TextBox Name="AnswerInput" Text="{Binding UserAnswer, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="16" Padding="5" Margin="0,10"/>

            <Button Content="SUBMIT" Command="{Binding SubmitCommand}" IsDefault="True" Height="40" Background="#3498DB" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
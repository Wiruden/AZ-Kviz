<Window x:Class="az_kviz.Views.QuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:az_kviz.ViewModels"
        xmlns:local="clr-namespace:az_kviz.Views"
        mc:Ignorable="d"
        Title="QuestionDialog" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="CATEGORY: GEOGRAPHY" Foreground="Gray" FontWeight="Bold"/>
            <TextBlock Text="What is the capital city of the Czech Republic?" 
                       FontSize="20" TextWrapping="Wrap" Margin="0,20"/>

            <TextBox Name="AnswerBox" Height="40" FontSize="18" Margin="0,0,0,20"/>

            <UniformGrid Columns="2">
                <Button Content="SUBMIT" Height="40" Margin="5" FontWeight="Bold"/>
                <Button Content="I DON'T KNOW" Height="40" Margin="5"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>

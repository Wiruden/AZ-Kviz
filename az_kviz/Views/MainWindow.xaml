<Window x:Class="az_kviz.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:az_kviz.ViewModels"
        xmlns:v="clr-namespace:az_kviz.Views"
        mc:Ignorable="d"
        Title="AZ Kvíz" Height="600" Width="900">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:GameViewModel}">
            <v:GameView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid Margin="20" Visibility="{Binding IsMenuVisible}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <Button Content="P V P" Command="{Binding StartPvPCommand}" 
                        Background="White" Foreground="Black" 
                        Height="60" Margin="0,0,0,5" FontSize="24" FontWeight="Bold"/>

                <Button Content="VS. AI" Command="{Binding StartAICommand}" 
                        Background="White" Foreground="Black" 
                        Height="60" Margin="0,0,0,5" FontSize="24" FontWeight="Bold"/>

                <Button Content="QUIT" Command="{Binding QuitCommand}" 
                        Background="White" Foreground="Black" 
                        Height="60" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <Button Content="ABOUT APP" Command="{Binding ShowAboutCommand}" 
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                    Background="White" Foreground="Black" 
                    Width="180" Height="40" Margin="0,0,10,10"/>
        </Grid>

        <Grid>
            <Grid Margin="20" Visibility="{Binding IsMenuVisible}">
            </Grid>

            <ContentControl Content="{Binding CurrentView}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:MainViewModel}" />
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
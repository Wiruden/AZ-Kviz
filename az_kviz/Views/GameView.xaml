                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="V" Style="{StaticResource HexTileStyle}" Canvas.Top="312" Canvas.Left="300" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="Z" Style="{StaticResource HexTileStyle}" Canvas.Top="312" Canvas.Left="360" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 

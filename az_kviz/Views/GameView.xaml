                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="Ř" Style="{StaticResource HexTileStyle}" Canvas.Top="260" Canvas.Left="390" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

            <ToggleButton Content="S" Style="{StaticResource HexTileStyle}" Canvas.Top="312" Canvas.Left="60" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="Š" Style="{StaticResource HexTileStyle}" Canvas.Top="312" Canvas.Left="120" 

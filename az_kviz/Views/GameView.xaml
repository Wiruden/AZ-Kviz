            <ToggleButton Content="Ž" Style="{StaticResource HexTileStyle}" Canvas.Top="312" Canvas.Left="420" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
        </Canvas>
    </Grid>
</UserControl>
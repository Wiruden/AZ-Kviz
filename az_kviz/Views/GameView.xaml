<UserControl x:Class="az_kviz.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:az_kviz.ViewModels"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#F0F0F0">
            <TextBlock Text="Current Player" FontWeight="Bold" Margin="0,0,0,5" />
            <Label Content="{Binding CurrentPlayerName}" FontSize="16" BorderBrush="Black" BorderThickness="1" Margin="0,0,0,20" />

            <TextBlock Text="Time Remaining:" Margin="0,0,0,5" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding TimerValue}" Height="20" Foreground="Orange" />

            <Separator Margin="0,20" />
            <TextBlock Text="SCORES" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Player 1 (Red): " Foreground="#FFD62222" />
                <TextBlock Text="{Binding Player1Score}" Foreground="#FFD62222" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Player 2 (Blue): " Foreground="#FF234E9B" />
                <TextBlock Text="{Binding Player2Score}" Foreground="#FF234E9B" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <Canvas Grid.Column="1" Margin="20" Width="550" Height="500" HorizontalAlignment="Center">
            <ToggleButton Content="A" Style="{StaticResource HexTileStyle}" Canvas.Top="0" Canvas.Left="240" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

            <ToggleButton Content="B" Style="{StaticResource HexTileStyle}" Canvas.Top="52" Canvas.Left="210" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="C" Style="{StaticResource HexTileStyle}" Canvas.Top="52" Canvas.Left="270" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

            <ToggleButton Content="Č" Style="{StaticResource HexTileStyle}" Canvas.Top="104" Canvas.Left="180" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="D" Style="{StaticResource HexTileStyle}" Canvas.Top="104" Canvas.Left="240" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="E" Style="{StaticResource HexTileStyle}" Canvas.Top="104" Canvas.Left="300" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

            <ToggleButton Content="F" Style="{StaticResource HexTileStyle}" Canvas.Top="156" Canvas.Left="150" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="G" Style="{StaticResource HexTileStyle}" Canvas.Top="156" Canvas.Left="210" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="H" Style="{StaticResource HexTileStyle}" Canvas.Top="156" Canvas.Left="270" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>
            <ToggleButton Content="CH" Style="{StaticResource HexTileStyle}" Canvas.Top="156" Canvas.Left="330" 
                          Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}}"/>

            <ToggleButton Content="I" Style="{StaticResource HexTileStyle}" Canvas.Top="208" Canvas.Left="120" 
